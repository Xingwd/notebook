[mysqld]
### 基础配置 ###
default_time_zone = '+8:00'  # 根据时区调整
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

### 性能优化 ###
# 缓冲池设置为可用内存的70-80%
innodb_buffer_pool_size = 8G  # 根据服务器内存调整
innodb_buffer_pool_instances = 8  # 每个实例至少1GB
innodb_log_file_size = 2G        # 建议总日志大小为缓冲池的25%
innodb_flush_log_at_trx_commit = 1  # ACID保证
innodb_flush_method = O_DIRECT
max_connections = 2000
thread_cache_size = 100
table_open_cache = 2000
skip_name_resolve = ON           # 禁用DNS反向解析

### 日志管理 ###
server-id = 1                    # 集群中唯一ID
log_bin = /var/lib/mysql/binlog  # 二进制日志
binlog_format = ROW              # 推荐ROW格式
binlog_expire_logs_seconds = 1209600  # 14天过期
slow_query_log = 1
long_query_time = 5              # 慢查询阈值(秒)
log_slow_extra = ON              # 记录额外信息
general_log = 0                  # 生产环境建议关闭

### 复制与高可用 ###
gtid_mode = ON
enforce_gtid_consistency = ON
binlog_checksum = CRC32
master_verify_checksum = ON
slave_sql_verify_checksum = ON

### InnoDB优化 ###
innodb_file_per_table = ON
innodb_autoinc_lock_mode = 2
innodb_io_capacity = 4000        # 根据存储设备IOPS调整
innodb_read_io_threads = 16
innodb_write_io_threads = 16

### 连接控制 ###
max_allowed_packet = 256M
wait_timeout = 600
interactive_timeout = 600
max_execution_time = 30000       # 30秒查询超时(milliseconds)

[mysql]
default-character-set = utf8mb4
